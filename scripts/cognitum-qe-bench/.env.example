# Cognitum QE cost-Pareto benchmark — local key config.
# Copy to `.env` (gitignored) and fill in, OR export these from ~/.zshrc / ~/.bashrc.
# An exported shell var ALWAYS wins over .env; .env only fills gaps.
# NEVER commit a real key. The benchmark reads keys from here — never from code.

# Worker key: scopes completions:low + completions:mid (NO high). Runs the cheap
# attempts (policy P1 and the cheap leg of P3).
COG_QE_BENCH_WORKER_KEY=cog_...

# Judge key: scopes completions:high (+ mid). The ONLY key that reaches high tier,
# used as the advisor / final judge (policy P2 and P3 escalations).
COG_QE_BENCH_JUDGE_KEY=cog_...

# Optional: override the API base (defaults to https://api.cognitum.one).
# COGNITUM_BASE_URL=https://api.cognitum.one
