[9.469715, "o", "\u001b[90m┌──────────────────────\u001b[39m\u001b[90m┬────────────────────────────────────────────────\u001b[39m\u001b[90m┬────────────┐\u001b[39m\r\n\u001b[90m│\u001b[39m \u001b[37m\u001b[1mField\u001b[22m\u001b[39m                \u001b[90m│\u001b[39m \u001b[37m\u001b[1mRule\u001b[22m\u001b[39m                                           \u001b[90m│\u001b[39m \u001b[37m\u001b[1mRequired\u001b[22m\u001b[39m   \u001b[90m│\u001b[39m\r\n\u001b[90m├──────────────────────\u001b[39m\u001b[90m┼────────────────────────────────────────────────\u001b[39m\u001b[90m┼────────────┤\u001b[39m\r\n\u001b[90m│\u001b[39m title                \u001b[90m│\u001b[39m Must be 15-200 chars, format: [Component] Act… \u001b[90m│\u001b[39m \u001b[31m\u001b[1mYES\u001b[22m\u001b[39m        \u001b[90m│\u001b[39m\r\n\u001b[90m├──────────────────────\u001b[39m\u001b[90m┼────────────────────────────────────────────────\u001b[39m\u001b[90m┼────────────┤\u001b[39m\r\n\u001b[90m│\u001b[39m stepsToReproduce     \u001b[90m│\u001b[39m Minimum 2 steps required                       \u001b[90m│\u001b[39m \u001b[31m\u001b[1mYES\u001b[22m\u001b[39m        \u001b[90m│\u001b[39m\r\n\u001b[90m├──────────────────────\u001b[39m\u001b[90m┼────────────────────────────────────────────────\u001b[39m\u001b[90m┼────────────┤\u001b[39m\r\n\u001b[90m│\u001b[39m expectedBehavior     \u001b[90m│\u001b[39m Minimum 10 characters                          \u001b[90m│\u001b[39m \u001b[31m\u001b[1mYES\u001b[22m\u001b[39m        \u001b[90m│\u001b[39m\r\n\u001b[90m├──────────────────────\u001b[39m\u001b[90m┼────────────────────────────────────────────────\u001b[39m\u001b[90m┼────────────┤\u001b[39m\r\n\u001b[90m│\u001b[39m actualBehavior       \u001b[90m│\u001b[39m Minimum 10 characters                          \u001b[90m│\u001b[39m \u001b[31m\u001b[1mYES\u001b[22m\u001b[39m        \u001b[90m│\u001b[39m\r\n\u001b[90m├──────────────────────\u001b[39m\u001b[90m┼────────────────────────────────────────────────\u001b[39m\u001b[90m┼────────────┤\u001b[39m\r\n\u001b[90m│\u001b[39m environment          \u001b[90m│\u001b[39m Must include vehicle_model and software_versi… \u001b[90m│\u001b[39m \u001b[31m\u001b[1mYES\u001b[22m\u001b[39m        \u001b[90m│\u001b[39m\r\n\u001b[90m└──────────────────────\u001b[39m\u001b[90m┴────────────────────────────────────────────────\u001b[39m\u001b[90m┴────────────┘\u001b[39m\r\n"]
