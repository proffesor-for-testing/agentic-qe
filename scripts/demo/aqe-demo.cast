[32.358422, "o", "\u001b[33m\u001b[1m  ┌─ Match: DEF-4512 [72% similarity] — \u001b[33mRELATED\u001b[39m\u001b[33m\u001b[22m\u001b[39m\r\n"]
[32.358511, "o", "\u001b[37m  │  \"[Navigation] Map rendering lag causes route overlay \"\u001b[39m\r\n\u001b[90m  │  Shared factors: Navigation component, High-speed scenario, Route display issue\u001b[39m\r\n\u001b[33m  └─ ████████████████████████░░░░░░░░░ 72%\u001b[39m\r\n\r\n"]
[33.559924, "o", "\u001b[33m  ┌────────────────────────────────────────────────────────────┐\u001b[39m\r\n"]
[33.560086, "o", "\u001b[33m  │ \u001b[39m\u001b[31m\u001b[1mRECOMMENDATION: \u001b[22m\u001b[39m\u001b[37mDo NOT create new defect.\u001b[39m               \u001b[33m │\u001b[39m\r\n\u001b[33m  │ \u001b[39m\u001b[37m\u001b[39m\u001b[37mDEF-4823 is a duplicate of \u001b[33m\u001b[1mDEF-3901\u001b[22m\u001b[39m\u001b[37m (94% match).\u001b[39m        \u001b[33m │\u001b[39m\r\n\u001b[33m  │ \u001b[39m\u001b[37m\u001b[39m\u001b[37mAction: Link to DEF-3901 and add BMW 3 Series (G20) 2024\u001b[39m\u001b[33m │\u001b[39m\r\n\u001b[33m  │ \u001b[39m\u001b[37m\u001b[39m\u001b[37mas an additional affected configuration.\u001b[39m                \u001b[33m │\u001b[39m\r\n\u001b[33m  └────────────────────────────────────────────────────────────┘\u001b[39m\r\n"]
[33.56019, "o", "\r\n"]
[33.560311, "o", "\u001b[90m\u001b[1m  💡 Why semantic search matters:\u001b[22m\u001b[39m\r\n\u001b[90m     Keyword match for \"route recalculation fails highway exit\" → 0 results\u001b[39m\r\n\u001b[90m     Semantic match catches \"route guidance freezes motorway junction\" → 94%\u001b[39m\r\n\u001b[90m     Different words, same defect. AI understands meaning, not just text.\u001b[39m\r\n"]
