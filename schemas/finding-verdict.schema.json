{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-qe.dev/schemas/finding-verdict.schema.json",
  "title": "FindingVerdict",
  "type": "object",
  "required": [
    "contract",
    "id",
    "title",
    "severity",
    "confidence",
    "evidence",
    "verdict",
    "refutations"
  ],
  "additionalProperties": true,
  "properties": {
    "contract": {
      "const": "finding-verdict@1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "file": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verdict": {
      "enum": [
        "upheld",
        "refuted",
        "uncertain"
      ]
    },
    "refutations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
